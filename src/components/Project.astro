---
import { getCollection } from "astro:content";
const allArticles = await getCollection("articles");
import { Badge } from "@/components/starwind/badge";
import ProjectCard from "./ProjectCard.astro";
---

<div class="grid grid-cols-1 md:grid-cols-3">
    {
        allArticles.map(
            (
                article: any, // Use parentheses () for implicit return
            ) => (
                <ProjectCard project={article} buttonText="View Article">
                    <div class="grid grid-cols-3 gap-4 p-8">
                        {/* Also fix the tech map here */}
                        {article.data.tech.map((item: string) => (
                            <Badge variant="info">
                                <h3 class="p-1 text-center text-sm">{item}</h3>
                            </Badge>
                        ))}
                    </div>
                </ProjectCard>
            ),
        )
    }
</div>
